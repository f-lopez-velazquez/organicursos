{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capacidades mínimas de OrganiCursos",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-set-webview-zoom",
    "dialog:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "ffprobe",
          "sidecar": true
        },
        {
          "name": "ffmpeg",
          "sidecar": true
        }
      ]
    }
  ]
}
